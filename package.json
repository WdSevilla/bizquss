{
  "name": "remarq",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, self-hosteable comment system",
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "db:migrate": "pnpm --filter @remarq/api run db:migrate"
  },
  "workspaces": [
    "packages/*",
    "adapters/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "vue-demi"]
  }
}
