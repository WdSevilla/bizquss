# Database — elegir uno
DB_DRIVER=sqlite          # sqlite | postgres
DATABASE_URL=./remarq.db  # o postgresql://user:pass@localhost:5432/remarq

# Servidor
PORT=3100
HOST=0.0.0.0
BASE_URL=http://localhost:3100

# Seguridad
JWT_SECRET=cambia_esto_en_produccion
SALT=cambia_esto_en_produccion

# OAuth — GitHub (requerido para auth social)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (opcional, para notificaciones)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tudominio.com

# Moderación
DEFAULT_MODERATION=pending   # pending | auto_approve
MAX_COMMENT_LENGTH=10000
