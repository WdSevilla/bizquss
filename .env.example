# Database — elegir uno
DB_DRIVER=sqlite          # sqlite | postgres
DATABASE_URL=./remarq.db  # o postgresql://user:pass@localhost:5432/remarq

# Servidor
PORT=3100
HOST=0.0.0.0
BASE_URL=http://localhost

# Seguridad
JWT_SECRET=cambia_esto_en_produccion
SALT=cambia_esto_en_produccion

# OAuth — GitHub
# Crea una OAuth App en: https://github.com/settings/developers
# Authorization callback URL: http://TU_NUC_IP/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Google (opcional)
# Crea credenciales en: https://console.cloud.google.com/apis/credentials
# URI de redireccionamiento autorizado: http://TU_NUC_IP/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL del panel admin (a donde redirigir después del login)
# En dev: http://localhost:5173  |  En prod: http://TU_NUC_IP  (nginx sirve el admin en /)
ADMIN_URL=http://localhost:5173

# Email (opcional, para notificaciones)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tudominio.com

# Moderación
DEFAULT_MODERATION=pending   # pending | auto_approve
MAX_COMMENT_LENGTH=10000
